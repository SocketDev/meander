{
  "name": "@divmain/meander",
  "version": "1.3.0",
  "description": "Walkthrough generator — annotated code walkthroughs with comments, hosted on Val Town",
  "license": "MIT",
  "author": "Dale Bustad <github@dale.link>",
  "type": "module",
  "packageManager": "pnpm@11.0.0-rc.5",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "meander": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "node --experimental-strip-types --no-warnings src/cli.mts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "@valtown/sdk": "1.0.0",
    "marked": "18.0.0"
  },
  "devDependencies": {
    "@types/node": "24.9.2",
    "@typescript/native-preview": "7.0.0-dev.20260415.1",
    "esbuild": "0.25.11",
    "fast-glob": "3.3.3",
    "oxfmt": "0.37.0",
    "oxlint": "1.52.0",
    "svgo": "4.0.1",
    "taze": "19.9.2",
    "typescript": "5.9.2",
    "yoctocolors-cjs": "2.1.3"
  }
}
