{
  "name": "@divmain/meander",
  "version": "1.3.0",
  "description": "Walkthrough generator — annotated code walkthroughs with comments, hosted on Val Town",
  "license": "MIT",
  "author": "Dale Bustad <github@dale.link>",
  "type": "module",
  "packageManager": "pnpm@11.0.0-rc.5",
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "meander": "./dist/cli.mjs"
  },
  "files": [
    "dist",
    "assets"
  ],
  "scripts": {
    "build": "tsc",
    "check": "node scripts/check.mts",
    "clean": "node scripts/clean.mts",
    "dev": "node scripts/dev.mts",
    "fix": "node scripts/fix.mts",
    "lint": "node scripts/lint.mts",
    "optimize-svgs": "node scripts/optimize-svgs.mts",
    "update": "node scripts/update.mts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@sinclair/typebox": "0.34.48",
    "@valtown/sdk": "1.0.0",
    "marked": "18.0.0",
    "node-html-parser": "7.1.0"
  },
  "devDependencies": {
    "@socketsecurity/lib": "5.24.0",
    "@types/node": "24.9.2",
    "@typescript/native-preview": "7.0.0-dev.20260415.1",
    "ecc-agentshield": "1.4.0",
    "esbuild": "0.25.11",
    "fast-glob": "3.3.3",
    "oxfmt": "0.37.0",
    "oxlint": "1.52.0",
    "svgo": "4.0.1",
    "taze": "19.9.2",
    "typescript": "5.9.2",
    "yoctocolors-cjs": "2.1.3"
  },
  "peerDependencies": {
    "esbuild": ">=0.25",
    "mermaid": ">=11",
    "puppeteer": ">=23",
    "svgo": ">=4"
  },
  "peerDependenciesMeta": {
    "esbuild": {
      "optional": true
    },
    "mermaid": {
      "optional": true
    },
    "puppeteer": {
      "optional": true
    },
    "svgo": {
      "optional": true
    }
  }
}
